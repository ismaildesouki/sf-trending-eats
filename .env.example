# SF Trending Eats Configuration
# Copy this file to .env and fill in your values

# ============================================================
# GOOGLE SHEETS (database replacement)
# ============================================================
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here
GOOGLE_SHEETS_CREDENTIALS_FILE=credentials.json

# ============================================================
# API KEYS: Data Sources
# ============================================================

# Yelp Fusion API
# Get yours at: https://www.yelp.com/developers/v3/manage_app
YELP_API_KEY=your_yelp_api_key_here

# Reddit API (OAuth2)
# Create an app at: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=sf-trending-eats/1.0

# Google Places API
# Enable at: https://console.cloud.google.com/apis/library/places-backend.googleapis.com
GOOGLE_PLACES_API_KEY=your_google_places_key

# Threads API (Meta)
# Set up at: https://developers.facebook.com
THREADS_ACCESS_TOKEN=your_threads_access_token

# ============================================================
# API KEYS: Publishing
# ============================================================

# Beehiiv Newsletter
# Get yours at: https://app.beehiiv.com/settings/integrations
BEEHIIV_API_KEY=your_beehiiv_api_key
BEEHIIV_PUBLICATION_ID=your_publication_id

# Genviral (OpenClaw social posting)
# Get yours at: https://genviral.io
GENVIRAL_API_KEY=your_genviral_api_key

# ============================================================
# LLM (for content generation)
# ============================================================
ANTHROPIC_API_KEY=your_anthropic_api_key

# ============================================================
# APP SETTINGS
# ============================================================
# Bay Area bounding box (default covers SF, Oakland, San Jose)
GEO_LAT_CENTER=37.7749
GEO_LNG_CENTER=-122.4194
GEO_RADIUS_METERS=50000

# Scoring thresholds
TREND_SCORE_THRESHOLD=2.0
MIN_MENTIONS_TO_RANK=3

# Publishing
NEWSLETTER_SEND_DAY=tuesday
NEWSLETTER_SEND_HOUR=9
TOP_N_RESTAURANTS=10
